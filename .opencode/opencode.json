{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": true,
    "theme": "system",
    "tui": {
        "scroll_speed": 1,
        "scroll_acceleration": {
            "enabled": true
        }
    },
    "permission": {
        "doom_loop": "ask"
    },
    "formatter": {
        "prettier": {
            "command": ["npx", "prettier", "--write", "$FILE"],
            "extensions": [".js", ".jsx", ".ts", ".tsx", ".html", ".css", ".md", ".json", ".yaml", ".yml"]
        }
    }
}
